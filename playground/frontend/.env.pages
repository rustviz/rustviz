# Loaded by Vite when invoked with `--mode pages` (i.e. `npm run build:pages`).
# Sets the API origin the SPA will hit when it's hosted on GitHub Pages
# rather than served same-origin by rv-serve. Keep in sync with the CORS
# allowlist in rv-serve/src/main.rs.
VITE_API_BASE=https://rustviz-playground.fly.dev
